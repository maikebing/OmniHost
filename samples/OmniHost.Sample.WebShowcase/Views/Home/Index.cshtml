@model OmniHost.Sample.WebShowcase.Models.MvcDashboardViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>@Model.Title</title>
  <style>
    :root {
      --bg: #eef4ff;
      --card: rgba(255,255,255,0.92);
      --border: rgba(37, 99, 235, 0.14);
      --text: #0f172a;
      --muted: #475569;
      --accent: #2563eb;
    }

    * { box-sizing: border-box; }
    html, body { height: 100%; }
    body {
      margin: 0;
      font-family: "Segoe UI Variable", "Segoe UI", system-ui, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(37, 99, 235, 0.12), transparent 26%),
        radial-gradient(circle at top right, rgba(15, 118, 110, 0.12), transparent 24%),
        linear-gradient(180deg, #f8fbff 0%, var(--bg) 100%);
      padding: 24px;
    }

    .shell {
      max-width: 1080px;
      margin: 0 auto;
      display: grid;
      gap: 18px;
    }

    .hero,
    .panel {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 24px;
      box-shadow: 0 18px 50px rgba(37, 99, 235, 0.08);
    }

    .hero {
      padding: 24px;
      display: grid;
      gap: 14px;
    }

    .eyebrow {
      display: inline-flex;
      width: fit-content;
      padding: 7px 12px;
      border-radius: 999px;
      background: rgba(37, 99, 235, 0.08);
      color: var(--accent);
      font-weight: 700;
      font-size: .84rem;
    }

    h1, h2, p {
      margin: 0;
    }

    h1 {
      font-size: 2.3rem;
      letter-spacing: -.04em;
      line-height: 1.05;
    }

    p {
      color: var(--muted);
      line-height: 1.7;
      font-size: 1rem;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }

    .metric,
    .panel {
      padding: 18px;
    }

    .metric {
      border-radius: 18px;
      background: rgba(255,255,255,0.86);
      border: 1px solid rgba(37, 99, 235, 0.08);
    }

    .label {
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .08em;
      font-weight: 700;
      font-size: .76rem;
    }

    .value {
      margin-top: 8px;
      font-size: 1.05rem;
      font-weight: 700;
    }

    ul {
      margin: 0;
      padding-left: 18px;
      color: var(--muted);
      display: grid;
      gap: 8px;
    }

    code {
      background: rgba(15, 23, 42, 0.06);
      padding: 2px 6px;
      border-radius: 8px;
    }

    @@media (max-width: 900px) {
      .grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <main class="shell">
    <section class="hero">
      <span class="eyebrow">ASP.NET MVC Core</span>
      <h1>@Model.Title</h1>
      <p>@Model.Summary</p>
      <div class="grid">
        <div class="metric">
          <div class="label">Render Mode</div>
          <div class="value">Controller + Razor View</div>
        </div>
        <div class="metric">
          <div class="label">Timestamp</div>
          <div class="value">@Model.Timestamp</div>
        </div>
        <div class="metric">
          <div class="label">Shell</div>
          <div class="value">OmniHost desktop window</div>
        </div>
      </div>
    </section>

    <section class="panel">
      <h2>Why this sample exists</h2>
      <ul>
        @foreach (var item in Model.Highlights)
        {
          <li>@item</li>
        }
      </ul>
    </section>

    <section class="panel">
      <h2>Fit</h2>
      <p>
        Use this route when the app already has an MVC backend and the desktop shell should
        mostly host server-rendered pages. The OmniHost side only needs to point the window to
        <code>/mvc</code>.
      </p>
    </section>
  </main>
</body>
</html>
