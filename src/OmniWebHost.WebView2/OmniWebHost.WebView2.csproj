<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- No UseWindowsForms — raw Win32 P/Invoke only, enabling AOT compilation. -->
    <RootNamespace>OmniWebHost.WebView2</RootNamespace>
    <AssemblyName>OmniWebHost.WebView2</AssemblyName>
    <Version>0.1.0-preview.2</Version>
    <Description>Microsoft WebView2 adapter for OmniWebHost — AOT-compatible, raw Win32 window host.</Description>
    <NoWarn>MSB3277</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3856.49" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\OmniWebHost.Abstractions\OmniWebHost.Abstractions.csproj" />
  </ItemGroup>

</Project>


